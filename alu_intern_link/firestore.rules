rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Admin accounts are set by hand in the console (see app_user.dart),
    // so this just checks the caller's own user document for that flag.
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /startups/{startupId} {
      allow read: if isSignedIn();

      // A founder can only create a startup owned by themself, and it
      // always starts out "pending" - never verified on creation.
      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Founders can edit their own startup's details, but only an admin
      // may change its verification status.
      allow update: if isAdmin() ||
        (isOwner(resource.data.ownerUid) &&
         request.resource.data.status == resource.data.status);

      allow delete: if false;
    }

    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();

      // Only the owner of a startup that has actually been verified (and
      // not delisted) can post under it - this is the rule that stops an
      // unverified/fake startup from ever appearing in Discover, enforced
      // server-side.
      allow create: if isSignedIn() &&
        request.resource.data.postedByUid == request.auth.uid &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.ownerUid == request.auth.uid &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.status == 'verified' &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.isArchived != true;

      // Whoever posted it can edit it (e.g. open/close toggle, or the
      // startup-archive cascade) - unless an admin has removed it, in
      // which case only that admin can touch it again (restore it).
      // Admins can otherwise always update, to perform that removal.
      allow update: if isSignedIn() &&
        (isAdmin() ||
         (resource.data.postedByUid == request.auth.uid && resource.data.removedByAdmin != true));

      allow delete: if false;
    }

    match /applications/{applicationId} {
      // Only the student who applied, the founder whose startup owns the
      // opportunity, or an admin can see an application.
      allow read: if isSignedIn() &&
        (resource.data.studentUid == request.auth.uid ||
         isAdmin() ||
         get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.ownerUid == request.auth.uid);

      // A student can only ever create an application as themself, and it
      // always starts "pending".
      allow create: if isSignedIn() &&
        request.resource.data.studentUid == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Only the founder who owns the opportunity's startup can move an
      // application through review (pending/reviewed/accepted/rejected).
      allow update: if isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.ownerUid == request.auth.uid;

      allow delete: if false;
    }

    match /bookmarks/{bookmarkId} {
      // "Is this bookmarked?" listens on a doc that usually doesn't exist
      // yet (nothing has been saved there). When a doc doesn't exist,
      // `resource` is null, so we must allow that case explicitly -
      // otherwise `resource.data.studentUid` throws and every check of an
      // unsaved bookmark gets rejected as permission-denied.
      allow read: if isSignedIn() &&
        (resource == null || resource.data.studentUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.studentUid == request.auth.uid;
    }
  }
}
